# Public API URL used by the React app at build time (no trailing slash).
#
# Local dev (API on another port): leave unset for http://localhost:5103, or:
# VITE_API_BASE_URL=http://localhost:5103
#
# Production — API on a different host (e.g. old split deploy):
# VITE_API_BASE_URL=https://your-bookstore-api.azurewebsites.net
#
# Production — single App Service host (SPA copied into BookstoreAPI/wwwroot):
# VITE_API_BASE_URL=__SAME_ORIGIN__
